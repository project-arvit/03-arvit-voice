# ARVIT voice teammate environment.
#
# Copy to .env before running the container paths:  cp .env.example .env
# .env is gitignored; commit ONLY this .env.example. Secrets go via --env-file /
# the compose env_file — never hardcoded in the image or committed.

# --- Cloud LLM stage (the ONLY thing that leaves the Orin) ---
# AWS Bedrock via the Bedrock Runtime endpoint (bedrock-runtime.<region>.amazonaws.com,
# the InvokeModel path). The model below is a cross-region inference profile.
BEDROCK_REGION=eu-central-1
BEDROCK_MODEL=global.anthropic.claude-opus-4-8
# Bedrock bearer API key (ABSK...). Sent as `Authorization: Bearer`. Put the
# real value in .env only. Leave blank to fall back to the SigV4 credential
# chain (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / instance role).
BEDROCK_API_KEY=
# Back-compat fallbacks (used only if the BEDROCK_* names above are unset):
# AWS_REGION=eu-central-1
# BEDROCK_MODEL_ID=anthropic.claude-opus-4-8
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# --- Server bind (published port is bound to loopback by the run scripts) ---
HOST=127.0.0.1
PORT=8765

# --- Local STT (faster-whisper) — stays on the Orin ---
# Size: tiny|base|small|medium|large-v3 (tiny is the template default, ~75MB).
WHISPER_MODEL_SIZE=tiny
# On the Orin use device=cuda, compute_type=float16; cpu/int8 for laptops.
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Local TTS (Piper) — stays on the Orin ---
PIPER_VOICE=en_US-lessac-medium
# Optional absolute path to a downloaded Piper .onnx voice model.
# PIPER_MODEL_PATH=/models/piper/en_US-lessac-medium.onnx

# --- Barge-in / interruptions (Silero VAD cancels in-flight TTS) ---
ALLOW_INTERRUPTIONS=1
AUDIO_SAMPLE_RATE=16000
